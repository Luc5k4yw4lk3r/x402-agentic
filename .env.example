# Thirdweb secret key (get it from https://thirdweb.com/dashboard/settings/api-keys)
THIRDWEB_SECRET_KEY=your_thirdweb_secret_key_here

# Server wallet address - the wallet that will RECEIVE payments
# Get this from your thirdweb dashboard > Engine > Server Wallets
SERVER_WALLET_ADDRESS=0xYourServerWalletAddress

# Wallet that will PAY (client side) - private key for testing only
CLIENT_PRIVATE_KEY=0xYourClientPrivateKeyHere

# Server config
PORT=3000
